# Job Search Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Trello — get from trello.com/power-ups/admin
# Create or select a Power-Up, copy the API Key,
# then click "Token" to generate a read+write token.
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=your_trello_board_id_here

# Gmail OAuth credentials live in credentials.json (downloaded from Google Cloud Console)
# and gmail_token.json (auto-generated on first run via --gmail-setup).
# Neither file should be committed — both are in .gitignore.
